<?xml version="1.0" encoding="utf-8"?>
<!--
    冷启动屏隐形 icon - 108×108 dp 纯白填充。
    MIUI (HyperOS) 上 Android 12+ SplashScreen 拿到普通 PNG launcher icon 会
    fallback 到 bugdroid(绿机器人)icon,视觉突兀。让 windowSplashScreenAnimatedIcon
    指向一个白色实心 vector 盖在白色 windowSplashScreenBackground 上 = 视觉隐形,
    使系统 splash 表现为"纯白空屏",Compose SplashScreen 立即接管成为唯一可见屏。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M0,0h108v108h-108z"
        android:fillColor="#FFFFFF" />
</vector>
